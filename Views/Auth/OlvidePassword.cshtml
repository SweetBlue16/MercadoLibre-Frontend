@model OlvidePassword
@{
    ViewData["Title"] = "Recuperar contraseña";
}

<form asp-action="OlvidePassword" method="post">
    <div class="card mx-auto" style="max-width: 520px;">
        <div class="card-body">
            <h1 class="h4 text-center">@ViewData["Title"]</h1>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="Email" maxlength="40">
                <label asp-for="Email" class="form-label"></label>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
        </div>
        <div class="card-footer text-center">
            <button type="submit" class="btn btn-primary">Enviar instrucciones</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
