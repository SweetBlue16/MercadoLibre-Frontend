@model RestablecerPassword
@{
    ViewData["Title"] = "Restablecer contraseña";
}

<form asp-action="RestablecerPassword">
    <div class="card mx-auto" style="max-width: 560px;">
        <div class="card-body">
            <h1 class="h4 text-center">@ViewData["Title"]</h1>
            @if (TempData["Mensaje"] is string mensaje)
            {
                <div class="alert alert-info small">@mensaje</div>
            }
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="Email">
                <label asp-for="Email" class="form-label"></label>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Token" class="form-control" placeholder="Codigo">
                <label asp-for="Token" class="form-label"></label>
                <span asp-validation-for="Token" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Password" class="form-control" placeholder="Password">
                <label asp-for="Password" class="form-label"></label>
                <span asp-validation-for="Password" class="text-danger"></span>
                <div class="form-text">
                    La contraseña debe tener al menos 12 caracteres, una mayúscula, una minúscula, un número y un carácter especial.
                </div>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="ConfirmPassword" class="form-control" placeholder="ConfirmPassword">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
        </div>
        <div class="card-footer text-center">
            <button type="submit" class="btn btn-primary">Restablecer</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
