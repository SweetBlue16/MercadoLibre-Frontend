@model List<Pedido>
@{
    ViewData["Title"] = "Pedidos";
    ViewData["SubTitle"] = "Recibidos";
}

<h2 class="text-center mb-3">@ViewData["Title"] <small class="text-muted fs-5">@ViewData["SubTitle"]</small></h2>

@if (ViewData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row small mb-3">
    <div class="col text-end">
        Mostrando @Model.Count elementos
    </div>
</div>

@if (Model.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered small">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Usuario</th>
                    <th>Fecha</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.PedidoId</td>
                        <td>@(item.Usuario?.Email ?? "N/A")</td>
                        <td>@item.Fecha</td>
                        <td>@Html.DisplayFor(modelItem => item.Total)</td>
                        <td>
                            <a class="text-decoration-none small text-uppercase" asp-action="Detalle" asp-route-id="@item.PedidoId">Detalle</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="mt-5">
        <div class="alert alert-warning" role="alert">
            No se han encontrado pedidos.
        </div>
    </div>
}
