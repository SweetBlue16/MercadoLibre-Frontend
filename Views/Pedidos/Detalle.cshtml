@model Pedido
@{
    ViewData["Title"] = "Pedidos";
    ViewData["SubTitle"] = "Detalle";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
        <li class="breadcrumb-item">
            <a class="text-decoration-none" title="Regresar al listado" asp-action="Index">Listado</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">@ViewData["SubTitle"]</li>
    </ol>
</nav>

<h2 class="text-center mb-3">@ViewData["Title"] <small class="text-muted fs-5">@ViewData["SubTitle"]</small></h2>

@if (TempData["Mensaje"] is string mensaje)
{
    <div class="alert alert-success">@mensaje</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="card mb-3">
    <div class="card-body small">
        <div><strong>Pedido:</strong> @Model.PedidoId</div>
        <div><strong>Usuario:</strong> @(Model.Usuario?.Nombre ?? "N/A") (@(Model.Usuario?.Email ?? "N/A"))</div>
        <div><strong>Fecha:</strong> @Html.DisplayFor(model => model.Fecha)</div>
        <div><strong>Total:</strong> @Html.DisplayFor(model => model.Total)</div>
        <div><strong>Estado:</strong> @Model.Estado</div>
    </div>
</div>

<form asp-action="ActualizarEstado" asp-route-id="@Model.PedidoId" method="post" class="card mb-3">
    <div class="card-body small">
        <label class="form-label" for="Estado">Actualizar estado</label>
        <div class="input-group input-group-sm">
            <select id="Estado" name="Estado" class="form-select">
                @foreach (var estado in new[] { "Recibido", "Procesado", "Enviado", "En ruta de entrega", "Entregado" })
                {
                    <option value="@estado" selected="@(estado == Model.Estado)">@estado</option>
                }
            </select>
            <button class="btn btn-primary" type="submit">Guardar</button>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-bordered small">
        <thead>
            <tr>
                <th>Portada</th>
                <th>Producto</th>
                <th>Cantidad</th>
                <th>Precio</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Detalles)
            {
                <tr>
                    <td width="1">
                        <img src="@ImagenUrlHelper.Producto(Url, ViewBag.Url as string, item.Producto?.ArchivoId, item.Producto?.ImagenUrl)" alt="@item.Titulo" data-fallback-src="@ImagenUrlHelper.Placeholder(Url)" class="img-fluid img-thumbnail" style="max-height: 48px;">
                    </td>
                    <td>@item.Titulo</td>
                    <td>@item.Cantidad</td>
                    <td>@Html.DisplayFor(modelItem => item.Precio)</td>
                    <td>@Html.DisplayFor(modelItem => item.Subtotal)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="text-center mt-3">
    <a class="btn btn-sm btn-outline-secondary" asp-action="Index" title="Cancelar">Cancelar</a>
</div>
