@model Pedido
@{
    ViewData["Title"] = "Mis pedidos";
    ViewData["SubTitle"] = "Detalle";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb small">
        <li class="breadcrumb-item">
            <a class="text-decoration-none" asp-action="Index">Mis pedidos</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">@ViewData["SubTitle"]</li>
    </ol>
</nav>

<h2 class="text-center mb-3">@ViewData["Title"] <small class="text-muted fs-5">@ViewData["SubTitle"]</small></h2>

<div class="card mb-3">
    <div class="card-body small">
        <div><strong>Número de pedido:</strong> @Model.PedidoId</div>
        <div><strong>Fecha:</strong> @Model.Fecha</div>
        <div><strong>Total:</strong> @Html.DisplayFor(model => model.Total)</div>
        <div><strong>Estado:</strong> @Model.Estado</div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered small">
        <thead>
            <tr>
                <th>Portada</th>
                <th>Producto</th>
                <th>Cantidad</th>
                <th>Precio</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Detalles)
            {
                <tr>
                    <td width="1">
                        <img src="@ImagenUrlHelper.Producto(Url, ViewBag.Url as string, item.Producto?.ArchivoId)" alt="@item.Titulo" onerror="@ImagenUrlHelper.FallbackOnError(Url)" class="img-fluid img-thumbnail" style="max-height: 48px;">
                    </td>
                    <td>@item.Titulo</td>
                    <td>@item.Cantidad</td>
                    <td>@Html.DisplayFor(modelItem => item.Precio)</td>
                    <td>@Html.DisplayFor(modelItem => item.Subtotal)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="text-center mt-3">
    <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Regresar</a>
</div>
