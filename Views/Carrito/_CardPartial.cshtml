@model CarritoItem
@{
    var portadaUrl = ImagenUrlHelper.Producto(Url, ViewBag.Url as string, Model.ArchivoId);
}

<div class="card">
    <div class="row g-0 align-items-center">
        <div class="col-md-2 text-center bg-white p-2">
            <img src="@portadaUrl" alt="@Model.Titulo" onerror="@ImagenUrlHelper.FallbackOnError(Url)" class="img-fluid" style="max-height: 120px;">
        </div>
        <div class="col-md-6">
            <div class="card-body">
                <p class="card-text mb-1">@Model.Titulo</p>
                <h5 class="card-title mb-0">@Html.DisplayFor(model => model.Precio)</h5>
            </div>
        </div>
        <div class="col-md-2">
            <form asp-action="Actualizar" asp-route-id="@Model.ProductoId" method="post" class="d-flex gap-2 p-2">
                <input asp-for="Cantidad" min="1" max="99" class="form-control form-control-sm" />
                <button type="submit" class="btn btn-sm btn-outline-primary">Actualizar</button>
            </form>
        </div>
        <div class="col-md-2 text-end p-2">
            <div class="small text-muted">Subtotal</div>
            <div class="fw-semibold">@Html.DisplayFor(model => model.Subtotal)</div>
            <form asp-action="Eliminar" asp-route-id="@Model.ProductoId" method="post" class="mt-2">
                <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
            </form>
        </div>
    </div>
</div>
