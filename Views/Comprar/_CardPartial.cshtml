@model Producto
@{
    var portadaUrl = ImagenUrlHelper.Producto(Url, ViewBag.Url as string, Model.ArchivoId, Model.ImagenUrl);
}

<div class="card h-100">
    <div class="card-header text-center bg-white pt-3">
        <img src="@portadaUrl"
             alt="@Model.Titulo"
             onerror="@ImagenUrlHelper.FallbackOnError(Url)"
             class="img-fluid"
             loading="lazy"
             style="max-height: 200px; width: fit-content;">
    </div>

    <div class="card-body d-flex flex-column">
        <p class="card-text">
            <a asp-controller="Comprar"
               asp-action="Detalle"
               asp-route-id="@Model.ProductoId"
               class="link-dark link-underline-opacity-0 link-underline-opacity-75-hover fw-semibold">
                @Model.Titulo
            </a>
        </p>

        <h5 class="card-title">
            @Html.DisplayFor(model => model.Precio)
        </h5>

        <p class="card-text">
            @if (Model.Categorias != null)
            {
                foreach (var cat in Model.Categorias)
                {
                    <span class="badge rounded-pill text-bg-warning">@cat.Nombre</span>
                }
            }
        </p>

        <p class="mt-auto card-text text-success fw-semibold small">
            <i class="bi bi-lightning-fill"></i> Envío gratis
        </p>
    </div>

    <div class="card-footer">
        <form asp-controller="Carrito" asp-action="Agregar" asp-route-id="@Model.ProductoId" method="post">
            <button type="submit" class="btn btn-primary btn-sm">Agregar al carrito</button>
        </form>
    </div>
</div>
